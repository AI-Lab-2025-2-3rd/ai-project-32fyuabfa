print("Processed shapes:", X_train_proc_full.shape, test_pre_proc.shape)

# CV and Optuna objective
N_SPLITS = 5
skf = StratifiedKFold(n_splits=N_SPLITS, shuffle=True, random_state=42)
n_classes = len(np.unique(y_train))

# Default params (fallback)
DEFAULT_PARAMS = {
    "objective": "multiclass",
    "num_class": n_classes,
    "learning_rate": 0.03,
    "num_leaves": 64,
    "min_child_samples": 20,
    "feature_fraction": 0.9,
    "bagging_fraction": 0.8,
    "lambda_l1": 0.0,
    "lambda_l2": 1.0,
    "n_estimators": 2000,
    "class_weight": "balanced",
    "random_state": 42,
    "n_jobs": -1,
}

def cv_evaluate(params):
    # params: dict for LGBMClassifier (must include n_estimators)
    oof_probs = np.zeros((len(X_train), n_classes))
    for fold, (tr_idx, va_idx) in enumerate(skf.split(X_train, y_train)):
        # get fold splits
        X_tr_raw = X_train.iloc[tr_idx].reset_index(drop=True)
        y_tr_raw = y_train.iloc[tr_idx].reset_index(drop=True)
        X_va_raw = X_train.iloc[va_idx].reset_index(drop=True)

        # Fold-local preprocess: learn encodings from X_tr_raw and apply to X_va_raw
        X_tr_proc, X_va_proc = preprocess_with_train(X_tr_raw, y_tr_raw, X_va_raw)

        # Optional SMOTE on fold-train
        X_tr_res, y_tr_res = X_tr_proc, y_tr_raw
        if USE_SMOTE:
            try:
                sm = SMOTE(random_state=42, n_jobs=1)
                X_tr_res, y_tr_res = sm.fit_resample(X_tr_proc, y_tr_raw)
            except Exception:
                X_tr_res, y_tr_res = X_tr_proc, y_tr_raw

        # sample weights
        classes_local = np.unique(y_tr_res)
        cw = compute_class_weight("balanced", classes=classes_local, y=y_tr_res)
        wmap = dict(zip(classes_local, cw))
        sample_weight = np.array([wmap[c] for c in y_tr_res])

        # train
        model = lgb.LGBMClassifier(**params)
        callbacks = [lgb.early_stopping(stopping_rounds=100), lgb.log_evaluation(period=0)]
        model.fit(X_tr_res, y_tr_res, sample_weight=sample_weight, eval_set=[(X_va_proc, y_train.iloc[va_idx])], callbacks=callbacks)

        best_it = getattr(model, "best_iteration_", None)
        proba_va = model.predict_proba(X_va_proc, num_iteration=best_it)
        oof_probs[va_idx] = proba_va

    oof_preds = np.argmax(oof_probs, axis=1)
    score = f1_score(y_train, oof_preds, average="macro")
    return score

# If Optuna is available use it to tune; otherwise use defaults
if OPTUNA_AVAILABLE:
    def objective(trial):
        params = {
            "objective": "multiclass",
            "num_class": n_classes,
            "learning_rate": trial.suggest_float("learning_rate", 0.01, 0.05),
            "num_leaves": trial.suggest_int("num_leaves", 16, 128),
            "min_child_samples": trial.suggest_int("min_child_samples", 5, 80),
            "feature_fraction": trial.suggest_float("feature_fraction", 0.5, 1.0),
            "bagging_fraction": trial.suggest_float("bagging_fraction", 0.5, 1.0),
            "lambda_l1": trial.suggest_float("lambda_l1", 0.0, 5.0),
            "lambda_l2": trial.suggest_float("lambda_l2", 0.0, 5.0),
            "n_estimators": 3000,
            "class_weight": "balanced",
            "random_state": 42,
            "n_jobs": -1,
        }
        score = cv_evaluate(params)
        return score

    study = optuna.create_study(direction="maximize")
    N_TRIALS = 25
    print(f"Starting Optuna study ({N_TRIALS} trials)...")
    study.optimize(objective, n_trials=N_TRIALS)
    best_params = study.best_params
    best_params.update({"objective":"multiclass", "num_class": n_classes, "n_estimators":3000, "class_weight":"balanced", "random_state":42, "n_jobs":-1})
    print("Optuna finished. Best OOF Macro-F1:", study.best_value)
else:
    print("Optuna not available, using DEFAULT_PARAMS.")
    best_params = DEFAULT_PARAMS

# Final CV training with best_params, using fold-local preprocessing and final test preprocess derived from full train
print("\nStarting final CV training with best params...")
oof_probs_final = np.zeros((len(X_train), n_classes))
test_probs_final = np.zeros((len(test_pre_proc), n_classes))
models_dir = os.path.join(BASE, "models_fixed")
os.makedirs(models_dir, exist_ok=True)

for fold, (tr_idx, va_idx) in enumerate(skf.split(X_train, y_train), 1):
    print(f"\nFold {fold}/{N_SPLITS}")
    X_tr_raw = X_train.iloc[tr_idx].reset_index(drop=True)
    y_tr_raw = y_train.iloc[tr_idx].reset_index(drop=True)
    X_va_raw = X_train.iloc[va_idx].reset_index(drop=True)

    X_tr_proc, X_va_proc = preprocess_with_train(X_tr_raw, y_tr_raw, X_va_raw)

    # SMOTE
    X_tr_res, y_tr_res = X_tr_proc, y_tr_raw
    if USE_SMOTE:
        try:
            sm = SMOTE(random_state=42, n_jobs=1)
            X_tr_res, y_tr_res = sm.fit_resample(X_tr_proc, y_tr_raw)
        except Exception:
            X_tr_res, y_tr_res = X_tr_proc, y_tr_raw

    classes_local = np.unique(y_tr_res)
    cw = compute_class_weight("balanced", classes=classes_local, y=y_tr_res)
    wmap = dict(zip(classes_local, cw))
    sample_weight = np.array([wmap[c] for c in y_tr_res])

    model = lgb.LGBMClassifier(**best_params)
    model.fit(X_tr_res, y_tr_res, sample_weight=sample_weight, eval_set=[(X_va_proc, y_train.iloc[va_idx])],
              callbacks=[lgb.early_stopping(stopping_rounds=100), lgb.log_evaluation(period=0)])

    best_it = getattr(model, "best_iteration_", None)
    oof_probs_final[va_idx] = model.predict_proba(X_va_proc, num_iteration=best_it)

    # For test: we need to transform test using train mapping for this fold (preprocess_with_train)
    # Use mapping learned from X_tr_raw (train portion) to transform full test set
    _, test_proc_for_fold = preprocess_with_train(X_tr_raw, y_tr_raw, test_pre)
    test_probs_final += model.predict_proba(test_proc_for_fold, num_iteration=best_it) / N_SPLITS

    joblib.dump(model, os.path.join(models_dir, f"model_fold{fold}.pkl"))
    print(f"Saved fold model to: {models_dir}")

# Evaluate OOF
oof_preds_final = np.argmax(oof_probs_final, axis=1)
oof_f1 = f1_score(y_train, oof_preds_final, average="macro")
print("\n=== OOF Evaluation ===")
print("OOF Macro-F1:", round(oof_f1,4))
print(classification_report(y_train, oof_preds_final, digits=4))
print("Confusion Matrix:\n", confusion_matrix(y_train, oof_preds_final))

# Provided validation evaluation using ensemble of fold models
val_proba_agg = np.zeros((len(X_val_provided), n_classes))
for fname in sorted([f for f in os.listdir(models_dir) if f.endswith(".pkl")]):
    m = joblib.load(os.path.join(models_dir, fname))
    # apply mapping from the corresponding train fold: we don't persist mapping separately, but using preprocess_with_train with full train is acceptable for provided validation
    _, val_proc_for_model = preprocess_with_train(X_train, y_train, X_val_provided)
    val_proba_agg += m.predict_proba(val_proc_for_model, num_iteration=getattr(m,"best_iteration_",None)) / N_SPLITS
val_preds_ens = np.argmax(val_proba_agg, axis=1)
print("\nProvided Validation Macro-F1:", f1_score(y_val_provided, val_preds_ens, average="macro"))
print(classification_report(y_val_provided, val_preds_ens, digits=4))

# Save submission
submission = pd.DataFrame({"id": test_pre.index, "target": np.argmax(test_probs_final, axis=1)})
