# Safe conversions
def safe_prepare(df):
    df = df.copy()
    for c in df.columns:
        if df[c].dtype == object:
            df[c] = pd.to_numeric(df[c], errors='coerce')
    for c in df.columns:
        if df[c].isnull().any():
            df[c].fillna(df[c].mean(), inplace=True)
    return df

