# Feature engineering helpers (CV-safe TE, freq, interactions)
def target_encode_cv(train_series, train_y, valid_series, min_samples_leaf=20, smoothing=10):
    prior = train_y.mean()
    df = pd.DataFrame({"cat": train_series, "y": train_y})
    agg = df.groupby("cat")["y"].agg(["mean","count"]).reset_index()
    agg["smoothing"] = 1 / (1 + np.exp(-(agg["count"] - min_samples_leaf) / smoothing))
    agg["te"] = prior * (1 - agg["smoothing"]) + agg["mean"] * agg["smoothing"]
    mapping = dict(zip(agg["cat"], agg["te"]))
    return valid_series.map(mapping).fillna(prior).values

def freq_encode(series):
    vc = series.value_counts(dropna=False)
    return series.map(vc).fillna(0).values

def add_interactions(df, cols):
    df = df.copy()
    for i in range(len(cols)):
        for j in range(i+1, len(cols)):
            a, b = cols[i], cols[j]
            df[f"{a}_x_{b}"] = df[a] * df[b]
            denom = df[b].replace(0, np.nan)
            df[f"{a}_div_{b}"] = (df[a] / denom).fillna(0)
    return df

# Preprocess function that returns processed train and processed test (or validation) with same columns
def preprocess_with_train(train_x, train_y, other_x):
    # train_x: DataFrame (train portion)
    # train_y: Series aligned with train_x
    # other_x: DataFrame to be transformed using mappings learned from train_x (could be val or test)
    X_tr = train_x.reset_index(drop=True).copy()
    X_ot = other_x.reset_index(drop=True).copy()

    # find candidate categorical-like columns (object or low cardinality)
    cat_cols = [c for c in X_tr.columns if (X_tr[c].dtype == object) or (X_tr[c].nunique() <= 20)]
    for c in cat_cols:
        X_tr[c] = X_tr[c].fillna("NA")
        X_ot[c] = X_ot[c].fillna("NA")
        X_tr[c + "_te"] = target_encode_cv(X_tr[c], train_y, X_tr[c], min_samples_leaf=20, smoothing=10)
        X_ot[c + "_te"] = target_encode_cv(X_tr[c], train_y, X_ot[c], min_samples_leaf=20, smoothing=10)
        # frequency encoding
        freq = X_tr[c].value_counts()
        X_tr[c + "_freq"] = X_tr[c].map(freq).fillna(0)
        X_ot[c + "_freq"] = X_ot[c].map(freq).fillna(0)

    # interactions on numeric subset
    numeric_cols = X_tr.select_dtypes(include=[np.number]).columns.tolist()
    inter_cols = numeric_cols[:6] if len(numeric_cols) > 6 else numeric_cols
    if len(inter_cols) >= 2:
        X_tr = add_interactions(X_tr, inter_cols)
        X_ot = add_interactions(X_ot, inter_cols)

    # final safe numeric coercion
    X_tr = safe_prepare(X_tr)
    X_ot = safe_prepare(X_ot)
    return X_tr, X_ot

# Build processed full train and processed test using full training data as mapping source (important for final prediction)
print("Applying global processing to create final processed train/test for consistency...")
X_train_proc_full, test_pre_proc = preprocess_with_train(X_train, y_train, test_pre)
